# Environment Configuration Template
# =====================================
# Copy this file to .env and configure with your cloud service credentials
# Command: cp .env.example .env
# =====================================

# ================================
# Supabase Cloud Configuration (REQUIRED)
# ================================
# Get these from your Supabase dashboard:
# https://supabase.com/dashboard
# 
# 1. Go to Project Settings → API
# 2. Copy the following values:

# Your Supabase project URL (format: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ================================
# Clerk Configuration (REQUIRED)
# ================================
# Get these from your Clerk dashboard:
# https://dashboard.clerk.com/
#
# 1. Select your application
# 2. Go to API Keys
# 3. Copy the following values:

# Your Clerk publishable key (format: pk_test_... or pk_live_...)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Your Clerk secret key (format: sk_test_... or sk_live_...)
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Clerk URLs (keep these as is)
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# ================================
# OpenAI Configuration (REQUIRED)
# ================================
# Get your API key from: https://platform.openai.com/api-keys
#
# 1. Log in to OpenAI Platform
# 2. Go to API Keys section
# 3. Create a new API key

# Your OpenAI API key for AI-powered schema generation
# IF YOU DON'T HAVE AN OPENAI API KEY, THE APP WILL FALLBACK TO FAKER.JS FOR SCHEMA GENERATION
OPENAI_API_KEY=your_openai_api_key_here

# ================================
# Frontend URL Configuration (REQUIRED)
# ================================
# Set your frontend URL (e.g., http://localhost:3000 for local development)
NEXT_PUBLIC_FRONTEND_URL=your_frontend_url_here